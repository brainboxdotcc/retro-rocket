  <compounddef id="SPRITEWIDTH" kind="page">
    <compoundname>SPRITEWIDTH</compoundname>
    <title>SPRITEWIDTH Function</title>
    <briefdescription>
    </briefdescription>
    <detaileddescription>
<para><programlisting filename=".basic"><codeline><highlight class="normal">SPRITEWIDTH(sprite-handle)</highlight></codeline>
</programlisting></para>
<para>Returns the <bold>width</bold> of a sprite in pixels.</para>
<para><hruler/>
</para>
<sect1 id="SPRITEWIDTH_1examples-70_1s1"><sect2 id="SPRITEWIDTH_1examples-70_1s2"><sect3 id="SPRITEWIDTH_1examples-70">
<title>Examples</title><para><programlisting filename=".basic"><codeline><highlight class="normal">w<sp/>=<sp/>SPRITEWIDTH(player_sprite)</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>&quot;Width:<sp/>&quot;;<sp/>w</highlight></codeline>
</programlisting></para>
<para><programlisting filename=".basic"><codeline><highlight class="normal">IF<sp/>SPRITEWIDTH(enemy_sprite)<sp/>&gt;<sp/>100<sp/>THEN</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>PRINT<sp/>&quot;Large<sp/>enemy&quot;</highlight></codeline>
<codeline><highlight class="normal">ENDIF</highlight></codeline>
</programlisting></para>
<para><bold>See also:</bold> <ref refid="SPRITEHEIGHT" kindref="compound">SPRITEHEIGHT</ref> </para>
</sect3></sect2></sect1>
    </detaileddescription>
