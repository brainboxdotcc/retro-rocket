<doxygen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="compound.xsd" version="1.14.0" xml:lang="en-US">
  <compounddef id="DATAREADR" kind="page">
    <compoundname>DATAREADR</compoundname>
    <title>DATAREADR Function</title>
    <briefdescription>
    </briefdescription>
    <detaileddescription>
<para><programlisting filename=".basic"><codeline><highlight class="normal">value<sp/>=<sp/>DATAREADR</highlight></codeline>
</programlisting></para>
<para>Reads the next real (floating-point) value from the <computeroutput>DATA</computeroutput> stream.</para>
<para>Each call returns the next value and advances the read position.</para>
<para><hruler/>
</para>
<sect1 id="DATAREADR_1example-1_1s1"><sect2 id="DATAREADR_1example-1_1s2"><sect3 id="DATAREADR_1example-1_1s3"><sect4 id="DATAREADR_1example-1_1s4"><sect5 id="DATAREADR_1example-1">
<title>Example</title><para><programlisting filename=".basic"><codeline><highlight class="normal">DATA<sp/>1.5,<sp/>2.25,<sp/>3.75</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">PRINT<sp/>DATAREADR</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>DATAREADR</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>DATAREADR</highlight></codeline>
</programlisting></para>
<para>This prints:</para>
<para><programlisting filename=".basic"><codeline><highlight class="normal">1.5</highlight></codeline>
<codeline><highlight class="normal">2.25</highlight></codeline>
<codeline><highlight class="normal">3.75</highlight></codeline>
</programlisting></para>
<para><hruler/>
</para>
</sect5></sect4></sect3></sect2></sect1>
<sect1 id="DATAREADR_1behaviour-1_1s1"><sect2 id="DATAREADR_1behaviour-1_1s2"><sect3 id="DATAREADR_1behaviour-1_1s3"><sect4 id="DATAREADR_1behaviour-1_1s4"><sect5 id="DATAREADR_1behaviour-1">
<title>Behaviour</title><para><itemizedlist>
<listitem><para>Returns the next value from the <computeroutput>DATA</computeroutput> stream.</para>
</listitem><listitem><para>The value must be a real number.</para>
</listitem><listitem><para>The read position advances after each call.</para>
</listitem><listitem><para>Values are read in the order they appear in <computeroutput>DATA</computeroutput>.</para>
</listitem></itemizedlist>
</para>
<para><hruler/>
</para>
</sect5></sect4></sect3></sect2></sect1>
<sect1 id="DATAREADR_1errors-1_1s1"><sect2 id="DATAREADR_1errors-1_1s2"><sect3 id="DATAREADR_1errors-1_1s3"><sect4 id="DATAREADR_1errors-1_1s4"><sect5 id="DATAREADR_1errors-1">
<title>Errors</title><para><itemizedlist>
<listitem><para>Reading past the end of available data produces an error.</para>
</listitem><listitem><para>If the next value is not a real number, a runtime error is raised.</para>
</listitem></itemizedlist>
</para>
<para><hruler/>
</para>
</sect5></sect4></sect3></sect2></sect1>
