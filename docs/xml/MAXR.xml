<?xml version='1.0' encoding='UTF-8' standalone='no'?>
<doxygen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="compound.xsd" version="1.14.0" xml:lang="en-US">
  <compounddef id="MAXR" kind="page">
    <compoundname>MAXR</compoundname>
    <title>MAXR Function</title>
    <briefdescription>
    </briefdescription>
    <detaileddescription>
<para><programlisting filename=".basic"><codeline><highlight class="normal">MAXR(a,<sp/>b)</highlight></codeline>
</programlisting></para>
<para>Returns the <bold>larger</bold> of two real values.</para>
<para><hruler/>
</para>
<sect1 id="MAXR_1examples-91_1s1"><sect2 id="MAXR_1examples-91_1s2"><sect3 id="MAXR_1examples-91">
<title>Examples</title><para><programlisting filename=".basic"><codeline><highlight class="normal">REM<sp/>Simple<sp/>comparison</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>MAXR(3.5,<sp/>7.2)</highlight></codeline>
</programlisting></para>
<para><programlisting filename=".basic"><codeline><highlight class="normal">REM<sp/>Clamp<sp/>a<sp/>value<sp/>to<sp/>a<sp/>minimum</highlight></codeline>
<codeline><highlight class="normal">VALUE#<sp/>=<sp/>-1.25</highlight></codeline>
<codeline><highlight class="normal">VALUE#<sp/>=<sp/>MAXR(VALUE#,<sp/>0.0)</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>VALUE#</highlight></codeline>
</programlisting></para>
<para><programlisting filename=".basic"><codeline><highlight class="normal">REM<sp/>Use<sp/>in<sp/>an<sp/>expression</highlight></codeline>
<codeline><highlight class="normal">A#<sp/>=<sp/>2.75</highlight></codeline>
<codeline><highlight class="normal">B#<sp/>=<sp/>2.80</highlight></codeline>
<codeline><highlight class="normal">PRINT<sp/>&quot;Largest<sp/>is<sp/>&quot;;<sp/>MAXR(A#,<sp/>B#)</highlight></codeline>
</programlisting></para>
<para><hruler/>
</para>
</sect3></sect2></sect1>
<sect1 id="MAXR_1notes-88_1s1"><sect2 id="MAXR_1notes-88_1s2"><sect3 id="MAXR_1notes-88">
<title>Notes</title><para><itemizedlist>
<listitem><para>Both parameters must be <bold>real expressions</bold>.</para>
</listitem><listitem><para>Returns whichever value is higher.</para>
</listitem><listitem><para>Commonly used for clamping values or enforcing lower bounds with real numbers.</para>
</listitem><listitem><para>For integer values, use <ref refid="MAX" kindref="compound">MAX</ref>.</para>
</listitem></itemizedlist>
</para>
<para><hruler/>
</para>
<para><bold>See also:</bold> <ref refid="MAX" kindref="compound">MAX</ref> · <ref refid="MIN" kindref="compound">MIN</ref> · <ref refid="ABS" kindref="compound">ABS</ref> </para>
</sect3></sect2></sect1>
    </detaileddescription>
    <location file="docpages/basic-language-reference/functions/real/MAXR.md"/>
  </compounddef>
