REM ======================
REM FizzBuzz
REM ======================

FOR i = 1 TO 100
    PROCfizzbuzz(i)
NEXT

END


DEF PROCfizzbuzz(n)

    IF (n MOD 15) = 0 THEN
        PRINT "FizzBuzz"
    ELSE
        IF (n MOD 3) = 0 THEN
            PRINT "Fizz"
        ELSE
            IF (n MOD 5) = 0 THEN
                PRINT "Buzz"
            ELSE
                PRINT n
            ENDIF
        ENDIF
    ENDIF

ENDPROC
