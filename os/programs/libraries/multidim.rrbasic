DEF FNmulti_get2(name$, x, y)
    meta$ = FNmulti_meta$(name$)
    EVAL "__multi_sx = " + meta$ + "_x"
    idx = x + y * __multi_sx
    EVAL "__multi_tmp = " + name$ + "(" + STR$(idx) + ")"
= __multi_tmp

