ENDPROC

DEF FNmulti_meta$(name$)
= "__dimension_" + name$

DEF PROCdim2(name$, x, y)
    meta$ = FNmulti_meta$(name$)
    EVAL "DIM " + name$ + ", " + STR$(x * y)
    EVAL meta$ + "_x = " + STR$(x)
    EVAL meta$ + "_y = " + STR$(y)
ENDPROC

DEF PROCdim2$(name$, x, y)
    meta$ = FNmulti_meta$(name$)
    EVAL "DIM " + name$ + "$, " + STR$(x * y)
    EVAL meta$ + "_x = " + STR$(x)
    EVAL meta$ + "_y = " + STR$(y)
ENDPROC

